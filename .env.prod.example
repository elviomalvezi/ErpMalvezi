# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=app_financeiro
POSTGRES_USER=app_financeiro_user
POSTGRES_PASSWORD=TROQUE_SENHA_FORTE_AQUI

# ─── Backend ───────────────────────────────────────────────────────────────────
# Aponta para o container postgres (nome do service no compose)
DATABASE_URL=postgresql+asyncpg://app_financeiro_user:TROQUE_SENHA_FORTE_AQUI@postgres:5432/app_financeiro

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GERE_UMA_CHAVE_SECRETA_AQUI

ENVIRONMENT=production

# ─── MinIO (Storage de Anexos) ─────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=TROQUE_SENHA_MINIO_AQUI

STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=TROQUE_SENHA_MINIO_AQUI
STORAGE_BUCKET=appfinanceiro

# ─── E-mail (configure com o SMTP da empresa) ──────────────────────────────────
SMTP_HOST=smtp.suaempresa.com.br
SMTP_PORT=587
SMTP_USER=financeiro@suaempresa.com.br
SMTP_PASSWORD=senha_email
SMTP_FROM=financeiro@suaempresa.com.br
