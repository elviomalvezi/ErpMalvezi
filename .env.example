# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=app_financeiro
POSTGRES_USER=app_financeiro_user
POSTGRES_PASSWORD=dev_secret_123

# ─── MinIO (S3-compatible) ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ─── MailHog ──────────────────────────────────────────────────────────────────
# MailHog não requer configuração de variáveis de ambiente.
# SMTP: localhost:1025  |  Web UI: http://localhost:8025

# ─── Backend (FastAPI) ────────────────────────────────────────────────────────
# Estas variáveis serão usadas pela aplicação Python; ainda não usadas pelo Compose.
DATABASE_URL=postgresql+asyncpg://app_financeiro_user:dev_secret_123@localhost:5432/app_financeiro
SECRET_KEY=troque-esta-chave-em-producao-use-openssl-rand-hex-32
ENVIRONMENT=development

# ─── Storage (MinIO / S3) ─────────────────────────────────────────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin123
STORAGE_BUCKET=erpmalvezi

# ─── E-mail (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@erpmalvezi.local
